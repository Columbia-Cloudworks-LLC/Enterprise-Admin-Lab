{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Enterprise Admin Lab Configuration",
    "description": "Schema for per-lab configuration files stored in Labs/<name>.json",
    "type": "object",
    "required": ["metadata", "domain", "networks", "baseImages", "vmDefinitions", "globalHardwareDefaults", "storage"],
    "properties": {
        "metadata": {
            "type": "object",
            "required": ["name", "displayName"],
            "properties": {
                "name": {
                    "type": "string",
                    "pattern": "^[a-z0-9][a-z0-9-]{1,48}[a-z0-9]$",
                    "description": "URL-safe slug identifier for the lab"
                },
                "displayName": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 100
                },
                "description": { "type": "string" },
                "author": { "type": "string" },
                "created": { "type": "string", "format": "date-time" },
                "modified": { "type": "string", "format": "date-time" },
                "tags": {
                    "type": "array",
                    "items": { "type": "string" }
                }
            }
        },
        "domain": {
            "type": "object",
            "required": ["fqdn", "netbiosName", "functionalLevel"],
            "properties": {
                "fqdn": { "type": "string", "minLength": 3 },
                "netbiosName": { "type": "string", "minLength": 1, "maxLength": 15 },
                "functionalLevel": {
                    "type": "string",
                    "enum": ["Win2012R2", "Win2016", "Win2019"]
                },
                "safeModePassword": { "type": "string" }
            }
        },
        "credentials": {
            "type": "object",
            "properties": {
                "localAdminRef": { "type": "string" },
                "domainAdminRef": { "type": "string" },
                "dsrmRef": { "type": "string" }
            }
        },
        "guestDefaults": {
            "type": "object",
            "properties": {
                "locale": { "type": "string" },
                "timeZone": { "type": "string" },
                "installTimeoutMinutes": { "type": "integer", "minimum": 5, "maximum": 480 },
                "postInstallTimeoutMinutes": { "type": "integer", "minimum": 5, "maximum": 480 },
                "defaultTools": {
                    "type": "array",
                    "items": { "type": "string" }
                },
                "domainJoinOuPath": { "type": "string" }
            }
        },
        "networks": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": ["name", "switchType", "subnet"],
                "properties": {
                    "name": { "type": "string", "minLength": 1 },
                    "switchType": {
                        "type": "string",
                        "enum": ["Internal", "Private", "External"]
                    },
                    "subnet": {
                        "type": "string",
                        "description": "CIDR notation, e.g. 192.168.10.0/24"
                    },
                    "gateway": { "type": "string" },
                    "dnsServers": {
                        "type": "array",
                        "items": { "type": "string" }
                    }
                }
            }
        },
        "baseImages": {
            "type": "object",
            "properties": {
                "windowsServer2019": {
                    "type": "object",
                    "properties": {
                        "isoPath": { "type": "string" },
                        "productKey": { "type": "string" }
                    }
                },
                "windowsServer2022": {
                    "type": "object",
                    "properties": {
                        "isoPath": { "type": "string" },
                        "productKey": { "type": "string" }
                    }
                },
                "windowsClient": {
                    "type": "object",
                    "properties": {
                        "isoPath": { "type": "string" },
                        "productKey": { "type": "string" }
                    }
                },
                "linux": {
                    "type": "object",
                    "properties": {
                        "isoPath": { "type": "string" },
                        "distro": { "type": "string" }
                    }
                }
            }
        },
        "vmDefinitions": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": ["name", "role", "os", "generation", "network"],
                "properties": {
                    "name": { "type": "string", "minLength": 1 },
                    "role": {
                        "type": "string",
                        "enum": ["DomainController", "MemberServer", "Client", "Linux"]
                    },
                    "os": {
                        "type": "string",
                        "enum": ["windowsServer2019", "windowsServer2022", "windowsClient", "linux"]
                    },
                    "generation": {
                        "type": "integer",
                        "enum": [1, 2]
                    },
                    "secureBoot": {
                        "type": "boolean",
                        "description": "Only applicable to Generation 2 VMs"
                    },
                    "tpmEnabled": {
                        "type": "boolean",
                        "description": "Only applicable to Gen 2 Windows 11 client VMs"
                    },
                    "hardware": {
                        "type": "object",
                        "properties": {
                            "cpuCount": { "type": "integer", "minimum": 1, "maximum": 16 },
                            "memoryMB": { "type": "integer", "minimum": 512, "maximum": 65536 },
                            "diskSizeGB": { "type": "integer", "minimum": 20, "maximum": 2000 }
                        }
                    },
                    "network": {
                        "type": "string",
                        "description": "Reference to a network name defined in the networks array"
                    },
                    "staticIP": { "type": "string" },
                    "count": { "type": "integer", "minimum": 1, "default": 1 },
                    "notes": { "type": "string" },
                    "roles": {
                        "type": "array",
                        "items": {
                            "type": "string",
                            "enum": ["DomainController", "MemberServer", "Client", "Linux", "DNS"]
                        }
                    },
                    "guestConfiguration": {
                        "type": "object",
                        "properties": {
                            "computerName": { "type": "string", "minLength": 1, "maxLength": 15 },
                            "locale": { "type": "string" },
                            "timeZone": { "type": "string" },
                            "network": {
                                "type": "object",
                                "properties": {
                                    "ipAddress": { "type": "string" },
                                    "subnetMask": { "type": "string" },
                                    "gateway": { "type": "string" },
                                    "dnsServers": {
                                        "type": "array",
                                        "items": { "type": "string" }
                                    }
                                }
                            },
                            "domainJoin": {
                                "type": "object",
                                "properties": {
                                    "enabled": { "type": "boolean" },
                                    "ouPath": { "type": "string" },
                                    "credentialRef": { "type": "string" }
                                }
                            },
                            "tools": {
                                "type": "array",
                                "items": { "type": "string" }
                            },
                            "firstBootScript": { "type": "string" }
                        }
                    },
                    "domainController": {
                        "type": "object",
                        "properties": {
                            "deploymentType": {
                                "type": "string",
                                "enum": ["newForest", "additional"]
                            },
                            "sourceDcName": { "type": "string" }
                        }
                    },
                    "orchestration": {
                        "type": "object",
                        "properties": {
                            "phaseTag": {
                                "type": "string",
                                "enum": ["dc-primary", "dc-additional", "member", "client", "linux"]
                            },
                            "bootstrap": {
                                "type": "string",
                                "enum": ["winrm", "ssh", "none"]
                            }
                        }
                    }
                }
            }
        },
        "globalHardwareDefaults": {
            "type": "object",
            "required": ["cpuCount", "memoryMB", "diskSizeGB"],
            "properties": {
                "cpuCount": { "type": "integer", "minimum": 1, "maximum": 16 },
                "memoryMB": { "type": "integer", "minimum": 512, "maximum": 65536 },
                "diskSizeGB": { "type": "integer", "minimum": 20, "maximum": 2000 }
            }
        },
        "storage": {
            "type": "object",
            "required": ["vmRootPath"],
            "properties": {
                "vmRootPath": {
                    "type": "string",
                    "description": "Hyper-V VM and VHD storage root path (used in Phase 3 provisioning)"
                },
                "logsPath": { "type": "string" }
            }
        },
        "orchestration": {
            "type": "object",
            "properties": {
                "engine": {
                    "type": "string",
                    "enum": ["hybrid", "hyperv-only"],
                    "default": "hybrid"
                },
                "controller": {
                    "type": "string",
                    "enum": ["shared"],
                    "default": "shared"
                },
                "postProvisionEnabled": {
                    "type": "boolean",
                    "default": true
                },
                "playbookProfile": {
                    "type": "string",
                    "default": "default-ad"
                },
                "inventoryStrategy": {
                    "type": "string",
                    "enum": ["per-lab"],
                    "default": "per-lab"
                },
                "skipOrchestration": {
                    "type": "boolean",
                    "default": false
                }
            }
        }
    }
}
