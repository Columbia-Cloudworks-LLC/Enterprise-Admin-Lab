            "192.168.20.11"
          ]
        },
        "domainJoin": {
          "enabled": false,
          "ouPath": "",
          "credentialRef": ""
        },
        "tools": [],
        "firstBootScript": ""
      }
    },
    {
      "name": "DC02",
      "role": "DomainController",
      "roles": [
        "DomainController",
        "DNS"
      ],
      "os": "windowsServer2022",
      "generation": 2,
      "secureBoot": true,
      "tpmEnabled": false,
      "hardware": {
        "cpuCount": 2,
        "memoryMB": 4096,
        "diskSizeGB": 80
      },
      "network": "CorpInternal",
      "staticIP": "192.168.20.11",
